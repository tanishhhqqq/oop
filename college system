import java.util.Scanner;
import java.util.ArrayList;

abstract class College {
    String collegeName;

    College(String collegeName) {
        this.collegeName = collegeName;
    }

    abstract void showDetails();
}

class Student extends College {
    String studentName;
    int marks;
    char grade;
    double percentage;
    String result;

    Student(String collegeName, String studentName, int marks) {
        super(collegeName);
        this.studentName = studentName;
        this.marks = marks;
        calculateResult();
    }

    void calculateResult() {
        percentage = marks;

        if (marks >= 90)
            grade = 'A';
        else if (marks >= 75)
            grade = 'B';
        else if (marks >= 60)
            grade = 'C';
        else if (marks >= 50)
            grade = 'D';
        else
            grade = 'F';

        result = (marks >= 50) ? "Pass" : "Fail";
    }

    void showDetails() {
        System.out.println("\nCollege Name: " + collegeName);
        System.out.println("Student Name: " + studentName);
        System.out.println("Marks: " + marks);
        System.out.println("Percentage: " + percentage + "%");
        System.out.println("Grade: " + grade);
        System.out.println("Result: " + result);
    }
}

public class Abstractex {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        System.out.print("Enter College Name: ");
        String college = sc.nextLine();

        System.out.print("Enter number of students: ");
        int n = sc.nextInt();
        sc.nextLine();

        ArrayList<Student> list = new ArrayList<>();

        for (int i = 1; i <= n; i++) {
            System.out.println("\nEnter details of Student " + i);

            System.out.print("Enter Student Name: ");
            String name = sc.nextLine();

            System.out.print("Enter Marks: ");
            int marks = sc.nextInt();
            sc.nextLine();

            list.add(new Student(college, name, marks));
        }

        System.out.println("\n--- Student Details ---");
        for (Student s : list) {
            s.showDetails();
        }

        Student topper = list.get(0);
        for (Student s : list) {
            if (s.marks > topper.marks) {
                topper = s;
            }
        }

        System.out.println("\n--- Topper Student ---");
        topper.showDetails();

        sc.close();
    }
}
