import java.util.Scanner;

class Product {

    String name;
    double price;
    int quantity;

    Product(String name, double price, int quantity) {
        this.name = name;
        this.price = price;
        this.quantity = quantity;
    }

    double getTotal() {
        return price * quantity;
    }
}

public class ECommerceMenu {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        Product[] products = new Product[100];

        int count = 0;
        int choice;

        do {

            System.out.println("\n===== E-COMMERCE MENU =====");
            System.out.println("1. Add Product");
            System.out.println("2. View Products");
            System.out.println("3. Generate Invoice");
            System.out.println("4. Exit");

            System.out.print("Enter your choice: ");
            choice = sc.nextInt();

            switch (choice) {

                case 1:

                    sc.nextLine();

                    System.out.print("Enter product name: ");
                    String name = sc.nextLine();

                    System.out.print("Enter price: ");
                    double price = sc.nextDouble();

                    System.out.print("Enter quantity: ");
                    int quantity = sc.nextInt();

                    products[count++] = new Product(name, price, quantity);

                    System.out.println("Product added successfully!");

                    break;

                case 2:

                    if (count == 0) {

                        System.out.println("No products added yet.");

                    } else {

                        System.out.println("\n--- Product List ---");

                        for (int i = 0; i < count; i++) {

                            System.out.println(
                                (i + 1) + ". " +
                                products[i].name +
                                " | Price: " + products[i].price +
                                " | Qty: " + products[i].quantity
                            );
                        }
                    }

                    break;

                case 3:

                    double total = 0;

                    System.out.println("\n===== INVOICE =====");

                    System.out.println("Product\tPrice\tQty\tTotal");

                    for (int i = 0; i < count; i++) {

                        double itemTotal = products[i].getTotal();

                        total += itemTotal;

                        System.out.println(
                            products[i].name + "\t" +
                            products[i].price + "\t" +
                            products[i].quantity + "\t" +
                            itemTotal
                        );
                    }

                    double discount =
                        total > 100000 ? total * 0.20 :
                        total > 50000 ? total * 0.10 : 0;

                    System.out.println("Total Amount: " + total);
                    System.out.println("Discount: " + discount);
                    System.out.println("Final Amount: " + (total - discount));

                    break;

                case 4:

                    System.out.println("Thank you for using the system!");
                    break;

                default:

                    System.out.println("Invalid choice!");
            }

        } while (choice != 4);

        sc.close();
    }
}
